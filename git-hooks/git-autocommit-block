#!/bin/sh
#
# git-autocommit-block — global pre-commit guard
#
# Blocks all git commits unless the human explicitly sets GIT_HUMAN_APPROVED=1.
# Prevents AI tools (GitHub Copilot, autopilot agents, scripts) from committing
# without explicit human approval.
#
# Installed globally via: git config --global core.hooksPath ~/.config/git/hooks
# Source file tracked at:  Scripts/git-hooks/git-autocommit-block  (in any repo)
#
# HOW TO COMMIT (as a human):
#   PowerShell:
#     $env:GIT_HUMAN_APPROVED=1; git commit -m "your message"
#   Git Bash / WSL:
#     GIT_HUMAN_APPROVED=1 git commit -m "your message"
#
# BYPASS (use sparingly):
#   git commit --no-verify -m "your message"
#

if [ "$GIT_HUMAN_APPROVED" != "1" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  ⛔  COMMIT BLOCKED — HUMAN APPROVAL REQUIRED  ⛔        ║"
  echo "╠══════════════════════════════════════════════════════════╣"
  echo "║                                                          ║"
  echo "║  [git-autocommit-block] is active on this machine.      ║"
  echo "║  AI tools, autopilot agents and scripts are BLOCKED.    ║"
  echo "║                                                          ║"
  echo "║  TO COMMIT AS A HUMAN:                                   ║"
  echo "║                                                          ║"
  echo "║  PowerShell:                                             ║"
  echo "║    \$env:GIT_HUMAN_APPROVED=1                            ║"
  echo "║    git commit -m \"your message\"                          ║"
  echo "║                                                          ║"
  echo "║  Git Bash / WSL:                                         ║"
  echo "║    GIT_HUMAN_APPROVED=1 git commit -m \"your message\"     ║"
  echo "║                                                          ║"
  echo "║  BYPASS (careful):                                       ║"
  echo "║    git commit --no-verify -m \"your message\"              ║"
  echo "║                                                          ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

echo "✅ Human approval confirmed (GIT_HUMAN_APPROVED=1). Proceeding."
exit 0
