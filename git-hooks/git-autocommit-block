#!/bin/sh
#
# git-autocommit-block — global pre-commit guard
#
# Blocks all git commits unless the human sets GIT_HUMAN_APPROVED to a Unix
# timestamp (seconds since epoch) issued within the last 60 seconds.
# A static value like "1" or any old timestamp is rejected — the approval
# must be fresh and intentional, preventing persistent env var bypasses.
#
# Installed globally via: git config --global core.hooksPath ~/.config/git/hooks
# Source file tracked at:  git-hooks/git-autocommit-block  (in any repo)
#
# HOW TO COMMIT (as a human):
#   PowerShell:
#     $env:GIT_HUMAN_APPROVED = [DateTimeOffset]::UtcNow.ToUnixTimeSeconds()
#     git commit -m "your message"
#     $env:GIT_HUMAN_APPROVED = $null   # clear after use
#
#   Git Bash / WSL:
#     GIT_HUMAN_APPROVED=$(date +%s) git commit -m "your message"
#
# BYPASS (use sparingly — leave audit trail in commit message):
#   git commit --no-verify -m "your message"
#

APPROVED="$GIT_HUMAN_APPROVED"

# Require a fresh timestamp (within 60 seconds)
if echo "$APPROVED" | grep -qE '^[0-9]{10}$'; then
  NOW=$(date +%s)
  AGE=$((NOW - APPROVED))
  if [ "$AGE" -ge 0 ] && [ "$AGE" -le 60 ]; then
    echo "✅ Human approval confirmed (timestamp ${APPROVED}, age ${AGE}s). Proceeding."
    exit 0
  fi
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  ⛔  COMMIT BLOCKED — HUMAN APPROVAL REQUIRED  ⛔            ║"
echo "╠══════════════════════════════════════════════════════════════╣"
echo "║                                                              ║"
echo "║  [git-autocommit-block] requires a FRESH timestamp.         ║"
echo "║  Static values (e.g. =1) or old timestamps are rejected.   ║"
echo "║                                                              ║"
echo "║  TO COMMIT AS A HUMAN:                                       ║"
echo "║                                                              ║"
echo "║  PowerShell:                                                 ║"
echo "║    \$env:GIT_HUMAN_APPROVED = [DateTimeOffset]::             ║"
echo "║        UtcNow.ToUnixTimeSeconds()                           ║"
echo "║    git commit -m \"your message\"                              ║"
echo "║    \$env:GIT_HUMAN_APPROVED = \$null  # clear after use       ║"
echo "║                                                              ║"
echo "║  Git Bash / WSL:                                             ║"
echo "║    GIT_HUMAN_APPROVED=\$(date +%s) git commit -m \"msg\"       ║"
echo "║                                                              ║"
echo "║  BYPASS (careful):                                           ║"
echo "║    git commit --no-verify -m \"your message\"                  ║"
echo "║                                                              ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
exit 1
